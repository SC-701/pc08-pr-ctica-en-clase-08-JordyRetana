@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

@if (TempData["MensajeExito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["MensajeExito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["MensajeError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["MensajeError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="product-header">
    <div class="product-toolbar">
        <div>
            <h2 class="section-title mb-1">Catálogo de Productos</h2>
            <p class="section-subtitle mb-0">
                Consulta el inventario registrado con información de categoría, subcategoría, precio y stock.
            </p>
        </div>

        <a asp-page="./Agregar" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i> Agregar producto
        </a>
    </div>
</section>

@if (!Model.Productos.Any())
{
    <div class="page-card empty-state">
        <i class="bi bi-inboxes-fill"></i>
        <h4 class="fw-bold">No hay productos registrados</h4>
        <p class="mb-3">Empieza agregando tu primer producto al inventario.</p>
        <a asp-page="./Agregar" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Crear producto
        </a>
    </div>
}
else
{
    <div class="card table-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-modern align-middle">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Subcategoría</th>
                            <th>Precio ₡</th>
                            <th>Precio USD</th>
                            <th>Stock</th>
                            <th>Código</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Productos)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.Nombre</div>
                                    <div class="text-muted small">@item.Descripcion</div>
                                </td>
                                <td>
                                    <span class="badge-soft">@item.Categoria</span>
                                </td>
                                <td>
                                    <span class="badge-soft-success">@item.SubCategoria</span>
                                </td>
                                <td>₡ @item.Precio.ToString("N2")</td>
                                <td>@(item.PrecioUSD.HasValue ? $"$ {item.PrecioUSD.Value:N2}" : "-")</td>
                                <td>@item.Stock</td>
                                <td>@item.CodigoBarras</td>
                                <td class="text-center">
                                    <div class="d-flex flex-wrap justify-content-center gap-2">
                                        <a asp-page="./Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-page="./Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-page="./Eliminar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}