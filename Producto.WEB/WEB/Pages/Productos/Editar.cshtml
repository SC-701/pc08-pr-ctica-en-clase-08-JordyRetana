@page "{id:guid}"
@model Web.Pages.Productos.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<section class="mb-4">
    <h2 class="section-title mb-1">Editar Producto</h2>
    <p class="section-subtitle mb-0">Actualiza la información del producto seleccionado.</p>
</section>

<div class="card form-card">
    <div class="form-card-header">
        <h2><i class="bi bi-pencil-square me-2"></i> Edición de producto</h2>
    </div>
    <div class="form-card-body">
        <form method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Producto.Nombre" class="form-label"></label>
                    <input asp-for="Producto.Nombre" class="form-control" />
                    <span asp-validation-for="Producto.Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Producto.CodigoBarras" class="form-label"></label>
                    <input asp-for="Producto.CodigoBarras" class="form-control" />
                    <span asp-validation-for="Producto.CodigoBarras" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Producto.Descripcion" class="form-label"></label>
                <textarea asp-for="Producto.Descripcion" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Producto.Descripcion" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Producto.Precio" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">₡</span>
                        <input asp-for="Producto.Precio" class="form-control" type="number" step="0.01" />
                    </div>
                    <span asp-validation-for="Producto.Precio" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Producto.Stock" class="form-label"></label>
                    <input asp-for="Producto.Stock" class="form-control" type="number" />
                    <span asp-validation-for="Producto.Stock" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Producto.IdSubCategoria" class="form-label">Subcategoría</label>
                    <select asp-for="Producto.IdSubCategoria" class="form-select" asp-items="Model.SubCategorias">
                        <option value="">Seleccione una subcategoría</option>
                    </select>
                    <span asp-validation-for="Producto.IdSubCategoria" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save me-1"></i> Actualizar producto
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}