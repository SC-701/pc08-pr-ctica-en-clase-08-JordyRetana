@page
@model Web.Pages.Seguridad.RegistroModel
@{ ViewData["Title"] = "Registro"; }
<div class="row justify-content-center mt-4">
    <div class="col-lg-6 col-xl-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4"><div class="display-6 mb-2 text-success"><i class="bi bi-person-plus-fill"></i></div><h1 class="h3 mb-1">Crear cuenta</h1><p class="text-muted mb-0">Regístrate para ingresar al módulo de productos.</p></div>
                @if (!string.IsNullOrWhiteSpace(Model.MensajeError)) { <div class="alert alert-danger">@Model.MensajeError</div> }
                <form method="post">
                    <div class="mb-3"><label asp-for="NombreUsuario" class="form-label"></label><input asp-for="NombreUsuario" class="form-control" /><span asp-validation-for="NombreUsuario" class="text-danger small"></span></div>
                    <div class="mb-3"><label asp-for="CorreoElectronico" class="form-label"></label><input asp-for="CorreoElectronico" class="form-control" /><span asp-validation-for="CorreoElectronico" class="text-danger small"></span></div>
                    <div class="mb-3"><label asp-for="Contrasenia" class="form-label">Contraseña</label><input asp-for="Contrasenia" type="password" class="form-control" /><span asp-validation-for="Contrasenia" class="text-danger small"></span></div>
                    <div class="mb-4"><label asp-for="ConfirmarContrasenia" class="form-label">Confirmar contraseña</label><input asp-for="ConfirmarContrasenia" type="password" class="form-control" /><span asp-validation-for="ConfirmarContrasenia" class="text-danger small"></span></div>
                    <button type="submit" class="btn btn-success w-100"><i class="bi bi-person-plus-fill me-2"></i>Registrarse</button>
                </form>
                <div class="text-center mt-4"><span class="text-muted">¿Ya tienes cuenta?</span><a asp-page="/Seguridad/Login" class="ms-1">Inicia sesión</a></div>
            </div>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
