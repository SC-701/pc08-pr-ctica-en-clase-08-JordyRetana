<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventario</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WEB.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-app">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                    <span class="brand-logo">
                        <i class="bi bi-box-seam-fill"></i>
                    </span>
                    <span class="fw-bold">Inventario</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Index">
                                <i class="bi bi-house-door me-1"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Productos/Index">
                                <i class="bi bi-grid me-1"></i> Productos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Privacy">
                                <i class="bi bi-shield-lock me-1"></i> Privacidad
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <section class="hero-bar">
            <div class="container">
                <div class="hero-bar-content">
                    <div>
                        <h1 class="hero-title mb-1">Sistema de Gestión de Productos</h1>
                        <p class="hero-subtitle mb-0">
                            Administra inventario, precios, stock y subcategorías desde una sola plataforma.
                        </p>
                    </div>
                    <div class="hero-icon d-none d-md-flex">
                        <i class="bi bi-box2-heart-fill"></i>
                    </div>
                </div>
            </div>
        </section>
    </header>

    <div class="container app-main">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer mt-5">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
            <div class="text-white-50">
                &copy; 2026 - Inventario
            </div>
            <div>
                <a asp-area="" asp-page="/Privacy" class="footer-link">Política de Privacidad</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>